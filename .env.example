# Backend environment template.
# Copy this file to .env for local development and fill your real keys there.

# DeepSeek / OpenAI-compatible LLM API.
# Leave empty to use the rule-based fallback.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash

# Demo behavior. 1 = simulate latency/fallbacks, 0 = faster local debugging.
SIMULATE_LATENCY=1

# Public API base URL for split deployments.
# Leave empty for local serve.py and Cloudflare Pages Functions same-origin deploys.
# Only set this when the frontend must call a separate API origin.
# Example: https://api.example.com
API_BASE_URL=

# SQLite account database used by the FastAPI backend.
# Relative paths are resolved from the project root.
AUTH_DB_PATH=instance/leisure_done.sqlite3

# AMap Web Service API key.
# Purpose: server-side route planning, POI search, geocoding, weather.
# Used by FastAPI and Cloudflare Pages Functions under /api/amap/*.
AMAP_WEB_SERVICE_KEY=
AMAP_WEB_SERVICE_BASE_URL=https://restapi.amap.com

# AMap Web JS API key.
# Browser-facing map SDK key. Restrict it to your production domain in AMap.
# Served to the browser through /config.js; keep the source value in env.
AMAP_JS_API_KEY=
AMAP_SECURITY_JS_CODE=
